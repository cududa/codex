{
  "name": "@prompt-reviews/api",
  "version": "0.1.0",
  "private": true,
  "description": "Hono API for Codex Reviewer.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dev": "tsx watch src/index.ts",
    "lint": "biome lint src",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.4",
    "@hono/zod-validator": "0.8.0",
    "@prompt-reviews/contracts": "workspace:*",
    "hono": "4.12.25",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
