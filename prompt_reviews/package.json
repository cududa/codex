{
  "name": "prompt_reviews",
  "version": "1.0.0",
  "description": "Local prompt review applet with a UI and MCP tools.",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.web.json --noEmit && vite build",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "detector:hook:check": "tsx scripts/detector-hook.ts check",
    "detector:hook:install": "tsx scripts/detector-hook.ts install",
    "detector:post-commit-refresh": "tsx scripts/detector-post-commit-refresh.ts",
    "detector:rerun": "tsx scripts/detector-rerun.ts",
    "schema:json": "tsx scripts/write-json-schemas.ts",
    "start": "npm run build && node dist/server/server.js",
    "start:built": "node dist/server/server.js",
    "test": "vitest run",
    "test:contracts": "vitest run src/**/*.contract.test.ts src/**/*.schema.test.ts src/__tests__/public-contracts.test.ts --passWithNoTests",
    "test:structure": "tsx scripts/check-architecture.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "verify": "npm run typecheck && npm run test:structure && npm run test && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fastify": "^5.8.5",
    "lucide-react": "^1.18.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "4.11.2",
    "react-router": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
